From: Fort <fort@example.com>
Date: Thu, 25 Jun 2026 00:00:00 +0000
Subject: [PATCH] x86: fix build with GCC 15 C23 default (-std=gnu11)

GCC 15 changed its default C standard from gnu17 to gnu23. In C23,
bool/true/false are keywords and cannot be redefined, which conflicts
with Linux's <linux/stddef.h> and <linux/types.h>.

Two x86 sub-Makefiles reset KBUILD_CFLAGS completely, losing the
-std=gnu11 flag set by the top-level Makefile:

  arch/x86/boot/compressed/Makefile:
    Starts fresh with -m$(BITS) -O2, no -std= flag.

  drivers/firmware/efi/libstub/Makefile:
    Resets cflags-y with `:=` for x86_32/x86_64, wiping the value
    captured from KBUILD_CFLAGS, then rebuilds KBUILD_CFLAGS from it.

Fix compressed/ by appending -std=gnu11 explicitly.
Fix libstub by saving $(filter -std=%,$(KBUILD_CFLAGS)) before the
reset and re-inserting it when rebuilding KBUILD_CFLAGS.

Signed-off-by: Fort <fort@example.com>
---
 arch/x86/boot/compressed/Makefile     | 1 +
 drivers/firmware/efi/libstub/Makefile | 4 ++++
 2 files changed, 5 insertions(+)

diff --git a/arch/x86/boot/compressed/Makefile b/arch/x86/boot/compressed/Makefile
index 1111111..2222222 100644
--- a/arch/x86/boot/compressed/Makefile
+++ b/arch/x86/boot/compressed/Makefile
@@ -27,6 +27,7 @@ KBUILD_CFLAGS := -m$(BITS) -O2 $(CLANG_FLAGS)
+KBUILD_CFLAGS += -std=gnu11
 KBUILD_CFLAGS += -fno-strict-aliasing -fPIE
 KBUILD_CFLAGS += -Wundef

diff --git a/drivers/firmware/efi/libstub/Makefile b/drivers/firmware/efi/libstub/Makefile
index 3333333..4444444 100644
--- a/drivers/firmware/efi/libstub/Makefile
+++ b/drivers/firmware/efi/libstub/Makefile
@@ -9,6 +9,9 @@
 # non-x86 reuses KBUILD_CFLAGS, x86 does not
 cflags-y			:= $(KBUILD_CFLAGS)

+# Preserve the C language standard flag across the x86 cflags reset below
+CC_FLAGS_STD			:= $(filter -std=%,$(KBUILD_CFLAGS))
+
 cflags-$(CONFIG_X86_32)		:= -march=i386
 cflags-$(CONFIG_X86_64)		:= -mcmodel=small
 cflags-$(CONFIG_X86)		+= -m$(BITS) -D__KERNEL__ \
@@ -36,6 +39,7 @@ cflags-$(CONFIG_EFI_PARAMS_FROM_FDT)	+= -I$(srctree)/scripts/dtc/libfdt

 KBUILD_CFLAGS			:= $(subst $(CC_FLAGS_FTRACE),,$(cflags-y)) \
 				   -Os -DDISABLE_BRANCH_PROFILING \
+				   $(CC_FLAGS_STD) \
 				   -include $(srctree)/include/linux/hidden.h \
 				   -D__NO_FORTIFY \
 				   -ffreestanding \
--
2.43.0
